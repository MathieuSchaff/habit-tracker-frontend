{
  "compilerOptions": {
    /* --- 1. Configuration Monorepo (Le rôle de fournisseur) --- */
    "composite": true, // OBLIGATOIRE : Permet au Backend et Frontend de "référencer" ce projet
    "rootDir": "./src", // Emplacement de tes fichiers sources (.ts)
    "outDir": "./dist", // Emplacement où les types générés (.d.ts) seront stockés

    /* --- 2. Sortie (Output) : Uniquement les types --- */
    "declaration": true, // Génère les fichiers .d.ts (le contrat de tes types)
    "declarationMap": false, // Désactivé pour rester léger (pas de lien vers le code source dans dist)
    "emitDeclarationOnly": true, // IMPORTANT : On ne génère pas de JS. Bun/Vite liront le TS directement.
    "noEmit": false, // On autorise la sortie (nécessaire pour générer les déclarations ci-dessus)

    /* --- 3. Résolution des Modules & Standard Moderne --- */
    "target": "ESNext", // Utilise les fonctionnalités JS les plus récentes
    "module": "ESNext", // Utilise le système d'import/export standard (ESM)
    "moduleResolution": "Bundler", // Indispensable pour Bun/Vite (permet d'omettre les extensions .ts)
    "lib": ["ESNext"], // Charge les types de base de JavaScript moderne
    "verbatimModuleSyntax": true, // Force une distinction claire entre import de type et import de code

    /* --- 4. Rigueur & Qualité (Sécurité maximale) --- */
    "strict": true, // Active toutes les vérifications (ex: interdit le 'any' implicite)
    "noUncheckedIndexedAccess": true, // Sécurité : vérifie si un élément existe avant d'accéder à un tableau
    "noUnusedLocals": true, // Erreur si une variable locale n'est pas utilisée
    "noUnusedParameters": true, // Erreur si un paramètre de fonction n'est pas utilisé
    "noFallthroughCasesInSwitch": true, // Empêche d'oublier un 'break' dans les switch

    /* --- 5. Compatibilité --- */
    "isolatedModules": true, // Garantit que chaque fichier peut être transpilé seul (requis par Bun/Vite)
    "esModuleInterop": true, // Permet d'importer des modules CommonJS proprement
    "skipLibCheck": true // Accélère la compilation en ignorant les types des librairies tierces
  },

  /* --- 6. Périmètre --- */
  "include": ["src/**/*"], // Inclus tout ce qui est dans shared/src
  "exclude": ["node_modules", "dist"] // Ignore les dépendances et le dossier de sortie
}
