# ==============================================================================
# Aurore — Production Environment
# ==============================================================================
# 1. Copy this file: cp .env.prod.example .env.prod
# 2. Fill in every value marked with CHANGE_ME
# 3. NEVER commit .env.prod to version control
#
# Generate secrets with: openssl rand -base64 32
# ==============================================================================

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_DB=appdb

# Strong password — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# Internal Docker hostname is 'db' (not localhost).
# Replace <POSTGRES_PASSWORD> with the same value as above.
DATABASE_URL=postgres://app:CHANGE_ME@db:5432/appdb

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# Must be at least 32 chars. Use a different value for each.
JWT_SECRET=CHANGE_ME
REFRESH_SECRET=CHANGE_ME

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ------------------------------------------------------------------------------
# Email — Resend (resend.com)
# ------------------------------------------------------------------------------
# Create an account, add a verified domain, then generate an API key.
RESEND_API_KEY=re_CHANGE_ME

# URL used for CORS and email verification links.
FRONTEND_URL=https://CHANGE_ME.com

# ------------------------------------------------------------------------------
# Google OAuth (console.cloud.google.com)
# ------------------------------------------------------------------------------
# In "Authorized redirect URIs" add: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://CHANGE_ME.com/api/auth/google/callback
