# ==============================================================================
# Aurore — Production Environment
# ==============================================================================
# 1. Copy this file: cp .env.prod.example .env.prod
# 2. Fill in every value marked with CHANGE_ME
# 3. NEVER commit .env.prod to version control
#
# Generate secrets with: openssl rand -base64 32
# ==============================================================================

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_DB=appdb

# Strong password — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# Internal Docker hostname is 'db' (not localhost).
# Replace <POSTGRES_PASSWORD> with the same value as above.
DATABASE_URL=postgres://app:CHANGE_ME@db:5432/appdb
# Runtime DB role password (used by APP_DATABASE_URL for the backend runtime pool).
# Rotate to a unique secret in production. Must match the password set via ALTER ROLE app_runtime PASSWORD '...'.
APP_RUNTIME_PASSWORD=CHANGE_ME
APP_DATABASE_URL=postgres://app_runtime:CHANGE_ME@db:5432/appdb

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# Must be at least 32 chars. Use a different value for each.
JWT_SECRET=CHANGE_ME
REFRESH_SECRET=CHANGE_ME

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ------------------------------------------------------------------------------
# Nginx / TLS
# ------------------------------------------------------------------------------
# Bare hostname (no scheme). Used by the nginx template + Let's Encrypt cert path.
# Must match the certbot-issued cert (see certbot init step in the runbook).
DOMAIN=CHANGE_ME.com

# ------------------------------------------------------------------------------
# Email — Brevo (brevo.com)
# ------------------------------------------------------------------------------
# Create an account, add a verified domain, then generate an API key.
BREVO_API_KEY=CHANGE_ME
# Sender identity for transactional emails. Domain MUST be authenticated in
# Brevo (DKIM/SPF/DMARC).
MAIL_FROM_EMAIL=noreply@CHANGE_ME.com
MAIL_FROM_NAME=Aurore

# URL used for CORS and email verification links.
FRONTEND_URL=https://CHANGE_ME.com

# ------------------------------------------------------------------------------
# Google OAuth (console.cloud.google.com)
# ------------------------------------------------------------------------------
# In "Authorized redirect URIs" add: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://CHANGE_ME.com/api/auth/google/callback

# ------------------------------------------------------------------------------
# Bunny.net — Image storage + CDN (bunny.net)
# ------------------------------------------------------------------------------
# Required: the backend refuses to boot in production if any of these is missing.
# Storage Zone name (Bunny dashboard → Storage).
BUNNY_STORAGE_ZONE=CHANGE_ME
# Storage hostname (region-dependent: storage.bunnycdn.com for DE, ny.storage.bunnycdn.com for NY, etc.).
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
# Storage Zone → FTP & API Access → Password (read-write).
BUNNY_STORAGE_PASSWORD=CHANGE_ME
# Pull Zone CDN base URL (e.g. https://aurore-cdn.b-cdn.net).
IMAGE_CDN_BASE=https://CHANGE_ME.b-cdn.net

# ------------------------------------------------------------------------------
# Catalogue owner (admin)
# ------------------------------------------------------------------------------
# The whole catalogue is owned by one admin. `just db-prod-admin` creates this
# user at deploy (idempotent), then `just db-catalogue-load` assigns every
# product to it. Use a real address + strong password (min 12 chars).
ADMIN_EMAIL=CHANGE_ME@CHANGE_ME.com
ADMIN_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------------------
# 📈 Observability — Grafana Cloud (docker-compose.monitoring.yml)
# ------------------------------------------------------------------------------
# Flux 1 — container logs. Alloy pushes to Grafana Cloud Loki (no local Loki/Grafana).
# Values from grafana.com → your stack → Loki → "Send logs" (URL + user + token).
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_API_TOKEN=

# Flux 3 — backend traces/metrics via OTel. Backend exports straight to the Cloud
# OTLP gateway (no Alloy). Empty endpoint = SDK off. From the stack's OTLP config;
# headers carry the auth: "Authorization=Basic <base64 instanceID:token>".
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=aurore-api

# Flux 2 — frontend RUM/analytics is a BUILD-TIME var (Vite), NOT set here.
# It's baked into the image via the VITE_FARO_URL GitHub Actions secret (build-push.yml).
