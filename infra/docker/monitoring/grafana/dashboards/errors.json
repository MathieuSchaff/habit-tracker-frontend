{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "Aurore — Errors",
  "uid": "aurore-errors",
  "schemaVersion": 39,
  "tags": ["aurore", "errors"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "container", "stream": "{job=\"docker\"}", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error rate (errors/min)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 40 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\", level=~\"error|fatal\"}[1m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=~\"$container\", level=~\"error|fatal\"}"
        }
      ]
    }
  ]
}
