# Local prod-like profiling: HTTP/2 + zstd/gzip + immutable assets.
# Prod nginx currently serves gzip only; this approximates its cache behavior
# while being closer to production than `vite preview`. Run via `just profile-prod`.
# Caddy auto-issues an internal-CA cert for localhost → accept the browser warning once.
localhost:8443 {
	# The stock Caddy image supports zstd + gzip. It does not serve Brotli.
	encode zstd gzip

	# API → backend on the host (app_api exposes :3000). `handle` keeps the /api prefix.
	handle /api/* {
		reverse_proxy host.docker.internal:3000
	}

	# Static SPA: hashed assets are immutable (no revalidation), everything else falls back to index.html.
	handle {
		root * /srv
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		try_files {path} /index.html
		file_server
	}
}
