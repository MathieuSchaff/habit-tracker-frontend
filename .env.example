# ==============================================================================
# 🌿 Aurore — Environment Configuration
# ==============================================================================
# Instructions:
# 1. Copy this file to .env.dev (for local development)
# 2. Fill in the values below.
# 3. DO NOT commit actual .env.dev or .env.prod files to version control!
# ==============================================================================

# 🗄️ Database (PostgreSQL)
# ------------------------------------------------------------------------------
# Password for the PostgreSQL root user.
POSTGRES_PASSWORD=your_secure_password_here
# Connection string (used by Drizzle ORM).
# Replace 'localhost' with 'db' when running inside Docker.
DATABASE_URL=postgres://app:devpassword@localhost:5432/appdb
# Runtime DB role password (used by APP_DATABASE_URL for the backend runtime pool).
# Rotate to a unique secret in production. Must match the password set via ALTER ROLE app_runtime PASSWORD '...'.
APP_RUNTIME_PASSWORD=change_me
APP_DATABASE_URL=postgres://app_runtime:change_me@localhost:5432/appdb

# 🔐 Authentication
# ------------------------------------------------------------------------------
# Random strings for signing JWTs. Recommendation: use `openssl rand -base64 32`.
JWT_SECRET=your_jwt_secret_here
REFRESH_SECRET=your_refresh_secret_here

# 📧 Email Service (Resend)
# ------------------------------------------------------------------------------
# API Key for sending verification emails.
RESEND_API_KEY=re_your_api_key_here
# URL of your frontend (for verification links).
FRONTEND_URL=http://localhost:5173

# 🌐 Google OAuth (Optional)
# ------------------------------------------------------------------------------
# Required if you want to enable "Login with Google".
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
